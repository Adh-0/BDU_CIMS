# ── BDU RAG Chatbot v2 — Environment Variables ──
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
LLM_PROVIDER=groq          # "groq" (cloud/dev) or "ollama" (local/deploy)

# --- Groq (cloud) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# --- LLM Generation ---
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
